<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Datentypen Briefumschlag Spiel</title>
<script type="text/javascript" src="https://ff.kis.v2.scr.kaspersky-labs.com/FD126C42-EBFA-4E12-B309-BB3FDD723AC1/main.js?attr=Rk6RhRXBRva877YNtwa9yzxtuhkFeTNfplzwfg4yGu8-29culmMqkXzBdqQp6uP9PdINKc9mQkuaWfT2B1IVpvfFkA1UdM6HWju4QuYijewAIFqJx7fheQYjBZy94FO5Z7zZMENFFz-HpUgnoRsX2mg7zmHfDdA-2HUanHacqJW16f95c-ESaQ684h7J2Tm849xwJnukUpNadocwZ-i8-Vwpr6drmuW6U09uZrM9hUs" charset="UTF-8"></script><link rel="stylesheet" crossorigin="anonymous" href="https://ff.kis.v2.scr.kaspersky-labs.com/E3E8934C-235A-4B0E-825A-35A08381A191/abn/main.css?attr=aHR0cHM6Ly9maWxlcmVwb3NpdG9yeS5pdHNsZWFybmluZy5jb20vYjYwMDc4NTItYmRkMS00ZTEwLTk2NGEtY2VjZmM0NmY2ZjY1P1Rva2VuPVlCQUxBQ2VfRFFEMzlSdHFBQUFBQUNBQXhrT3pBWEdNc3Uxd2xnc3dXeUJ1UEF0Z1EyVDZtZzdNbXZKZ1pBeFFYaG9BQUE"/><style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
    min-height: 100vh;
    padding: 20px;
    color: white;
  }
  h1 {
    text-align: center;
    font-size: 2em;
    margin-bottom: 8px;
    color: #e0e0ff;
    text-shadow: 0 2px 8px rgba(100,100,255,0.5);
  }
  .subtitle {
    text-align: center;
    color: #aaaacc;
    margin-bottom: 18px;
    font-size: 1em;
  }
  .controls {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 18px;
    margin-bottom: 18px;
    flex-wrap: wrap;
  }
  .controls label {
    font-size: 1em;
    color: #ccccea;
  }
  .controls select {
    padding: 6px 14px;
    border-radius: 8px;
    border: none;
    font-size: 1em;
    background: #23234a;
    color: white;
    cursor: pointer;
  }
  .score-board {
    display: flex;
    justify-content: center;
    gap: 30px;
    margin-bottom: 18px;
  }
  .score-item {
    background: rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 10px 24px;
    text-align: center;
    border: 1px solid rgba(255,255,255,0.15);
  }
  .score-num {
    font-size: 2em;
    font-weight: bold;
    color: #7ee8a2;
  }
  .score-num.wrong { color: #ff7b7b; }
  .score-label { font-size: 0.8em; color: #aaa; }
  .envelopes-container {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 24px;
    margin-bottom: 30px;
  }
  .envelope-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .envelope {
    width: 160px;
    height: 120px;
    position: relative;
    cursor: default;
    transition: transform 0.2s;
    filter: drop-shadow(0 4px 12px rgba(0,0,0,0.4));
  }
  .envelope-drop-zone {
    width: 160px;
    height: 120px;
    position: relative;
    border-radius: 8px;
    transition: box-shadow 0.2s;
  }
  .envelope-drop-zone.drag-over {
    box-shadow: 0 0 0 3px #fff, 0 0 18px 6px rgba(255,255,255,0.4);
    transform: scale(1.05);
  }
  .envelope-drop-zone.correct-flash {
    animation: flashGreen 0.7s ease;
  }
  .envelope-drop-zone.wrong-flash {
    animation: flashRed 0.7s ease;
  }
  @keyframes flashGreen {
    0%   { filter: drop-shadow(0 0 0px green); }
    30%  { filter: drop-shadow(0 0 30px #00ff88) brightness(1.4); }
    100% { filter: drop-shadow(0 0 0px green); }
  }
  @keyframes flashRed {
    0%   { filter: drop-shadow(0 0 0px red); }
    30%  { filter: drop-shadow(0 0 30px #ff4444) brightness(1.3); }
    100% { filter: drop-shadow(0 0 0px red); }
  }
  .envelope-label {
    text-align: center;
    font-size: 0.95em;
    color: #dde;
    font-weight: bold;
    line-height: 1.4;
  }
  .envelope-label span {
    display: block;
    font-size: 0.85em;
    color: #aaa;
    font-family: monospace;
  }
  .cards-area {
    background: rgba(255,255,255,0.06);
    border-radius: 16px;
    padding: 24px;
    min-height: 120px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    align-items: center;
    border: 2px dashed rgba(255,255,255,0.15);
    margin: 0 auto;
    max-width: 860px;
  }
  .card {
    background: linear-gradient(135deg, #2d2d6b, #3a3a8c);
    color: #fff;
    border-radius: 10px;
    padding: 12px 20px;
    font-size: 1.05em;
    font-family: monospace;
    font-weight: bold;
    cursor: grab;
    user-select: none;
    border: 2px solid rgba(255,255,255,0.2);
    box-shadow: 0 3px 10px rgba(0,0,0,0.3);
    transition: transform 0.15s, box-shadow 0.15s;
    white-space: nowrap;
  }
  .card:hover {
    transform: translateY(-3px) scale(1.04);
    box-shadow: 0 8px 20px rgba(0,0,0,0.4);
  }
  .card.dragging {
    opacity: 0.5;
    transform: scale(1.08);
    cursor: grabbing;
  }
  .btn-reset {
    display: block;
    margin: 22px auto 0 auto;
    padding: 12px 36px;
    font-size: 1.1em;
    background: linear-gradient(135deg, #6a11cb, #2575fc);
    color: white;
    border: none;
    border-radius: 30px;
    cursor: pointer;
    box-shadow: 0 4px 18px rgba(100,100,255,0.4);
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .btn-reset:hover {
    transform: scale(1.05);
    box-shadow: 0 8px 24px rgba(100,100,255,0.6);
  }
  .success-overlay {
    display: none;
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0,0,0,0.7);
    z-index: 100;
    justify-content: center;
    align-items: center;
  }
  .success-overlay.show { display: flex; }
  .success-box {
    background: linear-gradient(135deg, #1a1a3e, #2a2a6e);
    border-radius: 20px;
    padding: 48px 64px;
    text-align: center;
    box-shadow: 0 8px 40px rgba(100,100,255,0.5);
    border: 2px solid rgba(255,255,255,0.2);
  }
  .success-box h2 { font-size: 2.2em; color: #7ee8a2; margin-bottom: 12px; }
  .success-box p { font-size: 1.1em; color: #ccc; margin-bottom: 24px; }
  .cards-area-label {
    text-align: center;
    color: #aaa;
    font-size: 0.9em;
    margin-bottom: 8px;
  }
</style>
</head>
<body>

<h1>🎮 Datentypen-Spiel</h1>
<p class="subtitle">Ziehe die Karten in den richtigen Briefumschlag!</p>

<div class="controls">
  <label for="count-select">Anzahl der Karten pro Runde:</label>
  <select id="count-select">
    <option value="4">4 Karten</option>
    <option value="6">6 Karten</option>
    <option value="8">8 Karten</option>
    <option value="10">10 Karten</option>
    <option value="12">12 Karten</option>
    <option value="16">16 Karten</option>
  </select>
</div>

<div class="score-board">
  <div class="score-item">
    <div class="score-num" id="score-correct">0</div>
    <div class="score-label">Richtig ✅</div>
  </div>
  <div class="score-item">
    <div class="score-num wrong" id="score-wrong">0</div>
    <div class="score-label">Falsch ❌</div>
  </div>
  <div class="score-item">
    <div class="score-num" id="score-remaining" style="color:#f0e68c;">0</div>
    <div class="score-label">Verbleibend 🃏</div>
  </div>
</div>

<div class="envelopes-container" id="envelopes-container">
</div>

<p class="cards-area-label">📦 Ziehbereich – Karten hierher zurücklegen oder direkt in einen Umschlag ziehen</p>
<div class="cards-area" id="cards-area">
</div>

<button class="btn-reset" onclick="resetGame()">🔄 Neu starten & mischen</button>

<div class="success-overlay" id="success-overlay">
  <div class="success-box">
    <h2>🎉 Super gemacht!</h2>
    <p id="success-text">Du hast alle Karten richtig zugeordnet!</p>
    <button class="btn-reset" onclick="resetGame()">🔄 Nochmal spielen</button>
  </div>
</div>




<script>
//wichtig!!! immer gleich viele int str und bool

const ALL_CARDS = [
  { id: 'c1',  text: '42',                   type: 'int'   },
  { id: 'c2',  text: '-7',                   type: 'int'   },
  { id: 'c3',  text: '0',                    type: 'int'   },
  { id: 'c4',  text: '1000',                 type: 'int'   },
  { id: 'c5',  text: '"Otto"',               type: 'str'   },
  { id: 'c6',  text: '"TRUE"',               type: 'str'   },
  { id: 'c7',  text: '"Python"',             type: 'str'   },
  { id: 'c8',  text: '"123"',                type: 'str'   },
  { id: 'c9',  text: 'True',                 type: 'bool'  },
  { id: 'c10', text: 'False',                type: 'bool'  },
  { id: 'c11', text: '5 == 4',               type: 'bool'  },
  { id: 'c12', text: '3 > 1',                type: 'bool'  },
  { id: 'c13', text: '1.7',                  type: 'float' },
  { id: 'c14', text: '3.14',                 type: 'float' },
  { id: 'c15', text: '-0.5',                 type: 'float' },
  { id: 'c16', text: '2.718',                type: 'float' },
  { id: 'c17',  text: '"5+2"',               type: 'str'   },
  { id: 'c18',  text: '"True"',              type: 'str'   },
  { id: 'c19',  text: '"Python"=="Python"',  type: 'bool'  },
  { id: 'c20',  text: '"y==x',               type: 'bool'  },
  { id: 'c21',  text: 'x=5',                 type: 'int'   },
  { id: 'c22',  text: 'Python = 3',          type: 'int'   },
  { id: 'c23', text: '2.0',                  type: 'float' },
  { id: 'c24', text: 'x=x/5',                type: 'float' },
];
// maximale Anzahl an Einträgen
const lastOption = document.createElement('option');
lastOption.value = ALL_CARDS.length;
lastOption.textContent = `Alle (${ALL_CARDS.length})`;
document.getElementById('count-select').appendChild(lastOption);


const ENVELOPES = [
  {
    type: 'int',
    label: 'Ganze Zahl',
    func: 'int()',
    color1: '#e05c00', color2: '#ff9a44',
    flap1: '#c94d00', flap2: '#e06600'
  },
  {
    type: 'str',
    label: 'Zeichen / Buchstaben',
    func: 'str()',
    color1: '#1565c0', color2: '#42a5f5',
    flap1: '#0d47a1', flap2: '#1976d2'
  },
  {
    type: 'bool',
    label: 'Wahrheitswerte',
    func: 'bool()',
    color1: '#2e7d32', color2: '#66bb6a',
    flap1: '#1b5e20', flap2: '#388e3c'
  },
  {
    type: 'float',
    label: 'Fließkommazahlen',
    func: 'float()',
    color1: '#6a1b9a', color2: '#ab47bc',
    flap1: '#4a148c', flap2: '#7b1fa2'
  }
];

let scoreCorrect = 0;
let scoreWrong = 0;
let activeCards = [];
let draggedId = null;

function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function makeEnvelopeSVG(env) {
  return `
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 160 120" width="160" height="120">
    <defs>
      <linearGradient id="bg_${env.type}" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="${env.color1}"/>
        <stop offset="100%" stop-color="${env.color2}"/>
      </linearGradient>
      <linearGradient id="flap_${env.type}" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="${env.flap1}"/>
        <stop offset="100%" stop-color="${env.flap2}"/>
      </linearGradient>
    </defs>
    <!-- Envelope body -->
    <rect x="4" y="30" width="152" height="86" rx="8" fill="url(#bg_${env.type})" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
    <!-- Bottom triangle fold -->
    <polygon points="4,116 80,72 156,116" fill="${env.flap2}" opacity="0.6"/>
    <!-- Side folds -->
    <polygon points="4,30 4,116 60,73" fill="${env.flap1}" opacity="0.4"/>
    <polygon points="156,30 156,116 100,73" fill="${env.flap1}" opacity="0.4"/>
    <!-- Top flap (open) -->
    <polygon points="4,30 80,78 156,30" fill="url(#flap_${env.type})" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
    <!-- Seal dot -->
    <circle cx="80" cy="60" r="6" fill="rgba(255,255,255,0.25)" stroke="rgba(255,255,255,0.5)" stroke-width="1"/>
  </svg>`;
}

function buildEnvelopes() {
  const container = document.getElementById('envelopes-container');
  container.innerHTML = '';
  ENVELOPES.forEach(env => {
    const wrapper = document.createElement('div');
    wrapper.className = 'envelope-wrapper';

    const dropZone = document.createElement('div');
    dropZone.className = 'envelope-drop-zone';
    dropZone.id = 'envelope-' + env.type;
    dropZone.dataset.type = env.type;
    dropZone.innerHTML = makeEnvelopeSVG(env);

    dropZone.addEventListener('dragover', e => {
      e.preventDefault();
      dropZone.classList.add('drag-over');
    });
    dropZone.addEventListener('dragleave', () => {
      dropZone.classList.remove('drag-over');
    });
    dropZone.addEventListener('drop', e => {
      e.preventDefault();
      dropZone.classList.remove('drag-over');
      handleDrop(env.type, dropZone);
    });

    const lbl = document.createElement('div');
    lbl.className = 'envelope-label';
    lbl.innerHTML = env.label + '<span>' + env.func + '</span>';

    wrapper.appendChild(dropZone);
    wrapper.appendChild(lbl);
    container.appendChild(wrapper);
  });
}

function buildCards() {
  const area = document.getElementById('cards-area');
  area.innerHTML = '';
  const shuffled = shuffle(activeCards);
  shuffled.forEach(card => {
    const el = document.createElement('div');
    el.className = 'card';
    el.id = 'card-' + card.id;
    el.textContent = card.text;
    el.draggable = true;
    el.addEventListener('dragstart', () => {
      draggedId = card.id;
      setTimeout(() => el.classList.add('dragging'), 0);
    });
    el.addEventListener('dragend', () => {
      el.classList.remove('dragging');
    });
    area.appendChild(el);
  });
  updateRemaining();
}

function handleDrop(targetType, dropZone) {
  if (!draggedId) return;
  const card = activeCards.find(c => c.id === draggedId);
  if (!card) return;

  if (card.type === targetType) {
    // Correct
    scoreCorrect++;
    document.getElementById('score-correct').textContent = scoreCorrect;
    dropZone.classList.add('correct-flash');
    setTimeout(() => dropZone.classList.remove('correct-flash'), 700);
    const cardEl = document.getElementById('card-' + card.id);
    if (cardEl) cardEl.remove();
    activeCards = activeCards.filter(c => c.id !== card.id);
    updateRemaining();
    if (activeCards.length === 0) {
      setTimeout(showSuccess, 400);
    }
  } else {
    // Wrong
    scoreWrong++;
    document.getElementById('score-wrong').textContent = scoreWrong;
    dropZone.classList.add('wrong-flash');
    setTimeout(() => dropZone.classList.remove('wrong-flash'), 700);
    // Return card to area with shuffle (re-append)
    returnCardToArea(card.id);
  }
  draggedId = null;
}

function returnCardToArea(cardId) {
  const area = document.getElementById('cards-area');
  const cardEl = document.getElementById('card-' + cardId);
  if (cardEl) {
    // Remove and re-append at a random position among children
    area.removeChild(cardEl);
    const children = Array.from(area.children);
    if (children.length === 0) {
      area.appendChild(cardEl);
    } else {
      const pos = Math.floor(Math.random() * (children.length + 1));
      if (pos >= children.length) {
        area.appendChild(cardEl);
      } else {
        area.insertBefore(cardEl, children[pos]);
      }
    }
  }
}

function updateRemaining() {
  document.getElementById('score-remaining').textContent = activeCards.length;
}

function showSuccess() {
  const overlay = document.getElementById('success-overlay');
  document.getElementById('success-text').textContent =
    'Du hast alle Karten richtig zugeordnet! Richtig: ' + scoreCorrect + ' | Falsch: ' + scoreWrong;
  overlay.classList.add('show');
}

function resetGame() {
  document.getElementById('success-overlay').classList.remove('show');
  scoreCorrect = 0;
  scoreWrong = 0;
  document.getElementById('score-correct').textContent = '0';
  document.getElementById('score-wrong').textContent = '0';

  const count = parseInt(document.getElementById('count-select').value);
  // Pick cards ensuring variety: try to pick evenly from each type
  const byType = {};
  ENVELOPES.forEach(e => { byType[e.type] = shuffle(ALL_CARDS.filter(c => c.type === e.type)); });

  let selected = [];
  const perType = Math.floor(count / 4);
  const remainder = count % 4;
  ENVELOPES.forEach((e, i) => {
    const take = perType + (i < remainder ? 1 : 0);
    selected = selected.concat(byType[e.type].slice(0, take));
  });
  selected = shuffle(selected);
  activeCards = [...selected];

  buildEnvelopes();
  buildCards();
}

// Also rebuild when count changes
document.getElementById('count-select').addEventListener('change', resetGame);

// Initial game
resetGame();
</script>
</body>
</html>
